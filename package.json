    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "repo:verify": "tsx scripts/repo-engine-scripts/verify_repo.ts",
    "repo:fingerprint": "tsx scripts/repo-engine-scripts/gen_fingerprint_index.ts",
    "repo:symbols": "tsx scripts/repo-engine-scripts/gen_symbol_index.ts",
